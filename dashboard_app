<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LiteBI Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { background-color: #f8f9fa; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .sidebar { height: 100vh; background: #2c3e50; color: white; padding: 20px; position: fixed; width: 240px; }
        .main-content { margin-left: 260px; padding: 20px; }
        .viz-card { background: white; border-radius: 8px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); margin-bottom: 20px; }
        .field-item { padding: 8px; margin-bottom: 5px; background: #34495e; border-radius: 4px; cursor: pointer; font-size: 0.9rem; }
        .field-item:hover { background: #1abc9c; }
        .header-bar { background: white; padding: 15px; border-bottom: 1px solid #dee2e6; margin-bottom: 20px; }
    </style>
</head>
<body>

<div class="sidebar">
    <h5>Data Fields</h5>
    <hr>
    <div class="text-secondary mb-2 small">Dimensions</div>
    <div class="field-item">📅 Order Date</div>
    <div class="field-item">📍 Region</div>
    <div class="field-item">📦 Category</div>
    
    <div class="text-secondary mt-4 mb-2 small">Measures</div>
    <div class="field-item">💰 Sales</div>
    <div class="field-item">📈 Profit</div>
    <div class="field-item">🔢 Quantity</div>
</div>

<div class="main-content">
    <div class="header-bar d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Executive Sales Overview</h4>
        <button class="btn btn-primary btn-sm">+ Add Visualization</button>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="viz-card text-center">
                <small class="text-muted">Total Revenue</small>
                <h2 class="text-primary">$42,500</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="viz-card text-center">
                <small class="text-muted">Conversion Rate</small>
                <h2 class="text-success">12.5%</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="viz-card text-center">
                <small class="text-muted">Active Users</small>
                <h2 class="text-info">1,204</h2>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="viz-card">
                <h6>Monthly Sales Performance</h6>
                <canvas id="salesChart"></canvas>
            </div>
        </div>
        <div class="col-md-4">
            <div class="viz-card">
                <h6>Revenue by Region</h6>
                <canvas id="regionChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script>
    // Sales Line Chart Configuration
    const ctx1 = document.getElementById('salesChart').getContext('2d');
    new Chart(ctx1, {
        type: 'line',
        data: {
            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
            datasets: [{
                label: '2025 Revenue',
                data: [12000, 19000, 15000, 25000, 22000, 30000],
                borderColor: '#3498db',
                tension: 0.4,
                fill: true,
                backgroundColor: 'rgba(52, 152, 219, 0.1)'
            }]
        },
        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
    });

    // Region Doughnut Chart Configuration
    const ctx2 = document.getElementById('regionChart').getContext('2d');
    new Chart(ctx2, {
        type: 'doughnut',
        data: {
            labels: ['North', 'South', 'East', 'West'],
            datasets: [{
                data: [300, 500, 100, 200],
                backgroundColor: ['#1abc9c', '#3498db', '#9b59b6', '#e67e22']
            }]
        },
        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
    });
</script>

</body>
</html>
